# .env.example
# Hardcode these variables to instantly bypass the Jellyfin login screen on Smart TVs.
# This is highly recommended for building standalone WebOS/Tizen bundles, so you don't have to
# type URLs and passwords using a D-Pad remote.

VITE_JELLYFIN_SERVER_URL=http://192.168.1.100:8096
VITE_JELLYFIN_USER_ID=your_jellyfin_user_id
VITE_JELLYFIN_USER_NAME=your_username
VITE_JELLYFIN_TOKEN=your_api_token
